using AutoMapper;
using MindFit_Intelligence_Backend.DTOs.Responsables;
using MindFit_Intelligence_Backend.DTOs.Usuarios;
using MindFit_Intelligence_Backend.Models;
using MindFit_Intelligence_Backend.Repository.Interfaces;
using MindFit_Intelligence_Backend.Services.Interfaces;

namespace MindFit_Intelligence_Backend.Services
{
    public class ResponsableService : IResponsableService
    {
        private readonly IResponsableRepository _responsableRepository;
        private readonly IPersonaResponsableRepository _personaResponsableRepository;
        private readonly IMapper _mapper;
        private readonly IAuthService _authService;
        public List<string> Errors { get; } = new();

        public ResponsableService(
            IResponsableRepository responsableRepository,
            IPersonaResponsableRepository personaResponsableRepository,
            IMapper mapper,
            IAuthService authService)
        {
            _responsableRepository = responsableRepository;
            _personaResponsableRepository = personaResponsableRepository;
            _mapper = mapper;
            _authService = authService;
        }

        public async Task<List<UsuarioGridDto>> GetResponsablesGrid()
        {
            List<Usuario> responsables = await _responsableRepository.GetResponsablesGrid();
            return _mapper.Map<List<UsuarioGridDto>>(responsables);
        }

        public async Task<UsuarioDto?> GetResponsableById(int id)
        {
            Usuario? usuario = await _responsableRepository.GetResponsableCompletoById(id);
            if (usuario == null) return null;
            return _mapper.Map<UsuarioDto>(usuario);
        }

        public async Task<UsuarioDto?> Add(ResponsableInsertDto dto)
        {
            Errors.Clear();

            Usuario usuario = _mapper.Map<Usuario>(dto);
            _authService.SetPasswordHash(usuario, dto.Password);

            await _responsableRepository.Add(usuario);
            await _responsableRepository.Save();

            return await GetResponsableById(usuario.IdUsuario);
        }

        public async Task<UsuarioDto?> Update(int id, ResponsableUpdateDto dto)
        {
            Errors.Clear();

            Usuario? usuario = await _responsableRepository.GetById(id);
            if (usuario == null) return null;

            PersonaResponsable? pr = await _personaResponsableRepository.GetById(id);
            if (pr == null) return null;

            usuario.PersonaResponsable = pr;
            usuario.PersonaSocio = null;
            pr.Usuario = usuario;

            _mapper.Map(dto, usuario);

            if (dto.IdGrupos != null)
                await _responsableRepository.ReplaceUsuarioGrupos(id, dto.IdGrupos);

            await _responsableRepository.Save();

            UsuarioDto? usuarioDto = await GetResponsableById(id);
            if (usuarioDto == null)
            {
                Errors.Add("Error inesperado al obtener el responsable actualizado de la BD");
                return null;
            }

            return usuarioDto;
        }

        public async Task<UsuarioDto?> Delete(int id)
        {
            Usuario? usuarioRestore = await _responsableRepository.GetResponsableCompletoById(id);
            if (usuarioRestore == null) return null;
            UsuarioDto usuarioDto = _mapper.Map<UsuarioDto>(usuarioRestore);

            Usuario? usuarioDelete = await _responsableRepository.GetById(id);
            if (usuarioDelete == null) return null;

            _responsableRepository.Delete(usuarioDelete);
            await _responsableRepository.Save();

            return usuarioDto;
        }

        public Task<bool> ValidateDelete(int id)
        {
            Errors.Clear();
            return Task.FromResult(!Errors.Any());
        }
    }
}

